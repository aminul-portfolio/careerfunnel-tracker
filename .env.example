# Local development example
SECRET_KEY=replace-with-a-local-development-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost
CSRF_TRUSTED_ORIGINS=

# AI Career Coach local development example
# Mocked mode is the safe default for local development.
# Supported values:
# - mocked: uses the deterministic mocked provider
# - live: enables the optional live LLM provider spike
COACH_PROVIDER=mocked

# Optional live-provider API key.
# Required only when COACH_PROVIDER=live.
# Never commit a real API key.
COACH_API_KEY=replace-with-local-provider-key

# Production hosting example
# Set these as host environment variables. Do not commit a real .env file.
# DJANGO_SETTINGS_MODULE=config.settings.production
# SECRET_KEY=replace-with-a-real-host-secret
# DEBUG=False
# ALLOWED_HOSTS=your-app.example.com
# CSRF_TRUSTED_ORIGINS=https://your-app.example.com

# Production AI provider example
# Set these as host environment variables only if live mode is explicitly required.
# Keep mocked mode as the default unless a sprint explicitly approves live-provider testing.
# COACH_PROVIDER=mocked
# COACH_API_KEY=replace-with-host-provider-key
